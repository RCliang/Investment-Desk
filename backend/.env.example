# InvestLens 后端环境变量
#
# 使用方法：
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (macOS/Linux)
# 然后填入真实值。.env 文件已被 .gitignore 忽略，不会被提交。
#
# DEEPSEEK_API_KEY 留空时，应用仍可启动：
#   - LLM 服务会返回 mock 数据（见 services/llm_service.py）
#   - Tushare 接口会报错，但 akshare/astock 数据源仍可用

# DeepSeek API key — 产业链分析与报告生成
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# DeepSeek 接口地址（默认官方，可改为代理/自部署）
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型名：deepseek-chat (V3 通用对话，默认) / deepseek-reasoner (R1 推理增强)
# MODEL_NAME=deepseek-chat

# Tushare Pro token — 专业财务指标数据
# 申请：https://tushare.pro/register
TUSHARE_TOKEN=

# IWencai (同花顺) SkillHub API — 研报搜索 (see ADR-0005)
# 申请：https://www.iwencai.com/skillhub
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=
